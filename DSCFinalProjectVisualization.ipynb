    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "yfRLujegt_xH"
      },
      "outputs": [],
      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "import seaborn as sns\n",
        "#creating main dataframe\n",
        "folder_path = \"/content/drive/MyDrive/DetroitCrashData/\"\n",
        "import pandas as pd\n",
        "\n",
        "df_list = []\n",
        "\n",
        "for year in range(2011, 2025):\n",
        "    file_path = f\"{folder_path}crashes_{year}.csv\"\n",
        "    df = pd.read_csv(file_path)\n",
        "\n",
        "    df[\"year\"] = year\n",
        "\n",
        "    df_list.append(df)\n",
        "\n",
        "combined_df = pd.concat(df_list, ignore_index=True)\n"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "#cleaning dataframe for tableau map for bicycle crashes\n",
        "bike_df = combined_df[['Bicycle', 'Longitude', 'Latitude', 'geom', 'geog', 'x', 'y']].copy()\n",
        "bike_df.to_csv(\"detroitbike.csv\", index=False)\n",
        "clean_bike_df = bike_df[['Bicycle', 'Longitude', 'Latitude']]\n",
        "clean_bike_df.to_csv(\"cleandetroitbike.csv\", index=False)"
      ],
      "metadata": {
        "id": "tDW4BS4SpvhB"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "#preparing dataframe for cytoscape network\n",
        "import pandas as pd\n",
        "\n",
        "df = combined_df.copy()\n",
        "\n",
        "injury_cols = [\n",
        "    \"Fatal Injuries\",\n",
        "    \"Suspected Serious Injuries\",\n",
        "    \"Suspected Minor Injuries\",\n",
        "    \"Possible Injuries\",\n",
        "    \"Property Damage Only\"\n",
        "]\n",
        "\n",
        "df[injury_cols] = df[injury_cols].fillna(0).astype(int)\n",
        "\n",
        "\n",
        "risk_cols = [\n",
        "    \"Alcohol\",\n",
        "    \"Speeding Driver\",\n",
        "    \"Distracted Driver\",\n",
        "    \"Pedestrian\",\n",
        "    \"Bicycle\"\n",
        "]\n",
        "\n",
        "# Normalize to boolean vals\n",
        "for col in risk_cols:\n",
        "    df[col] = df[col].astype(str).str.lower().isin([\"true\", \"1\", \"yes\"])\n",
        "\n",
        "top_roads = df[\"Primary Road\"].value_counts().nlargest(10).index\n",
        "df = df[df[\"Primary Road\"].isin(top_roads)]\n",
        "\n",
        "keep_cols = [\"Primary Road\", \"severity\"] + risk_cols\n",
        "df = df[keep_cols]\n",
        "\n",
        "# Build edge list\n",
        "edges_list = []\n",
        "\n",
        "for col in risk_cols:\n",
        "    temp = df[df[col] == True]\n",
        "\n",
        "    grouped = temp.groupby(\"Primary Road\").size().reset_index(name=\"weight\")\n",
        "\n",
        "    grouped[\"target\"] = col\n",
        "    grouped = grouped.rename(columns={\"Primary Road\": \"source\"})\n",
        "\n",
        "    edges_list.append(grouped)\n",
        "\n",
        "edges = pd.concat(edges_list, ignore_index=True)\n",
        "\n",
        "# remove weak edges\n",
        "edges = edges[edges[\"weight\"] >= 3]\n",
        "\n",
        "#more cleaning\n",
        "edges[\"source\"] = edges[\"source\"].str.strip()\n",
        "edges[\"target\"] = edges[\"target\"].str.strip()\n",
        "\n",
        "edges = edges[[\"source\", \"target\", \"weight\"]]\n",
        "\n",
        "# Build node table\n",
        "road_nodes = pd.DataFrame({\n",
        "    \"name\": edges[\"source\"].unique(),\n",
        "    \"type\": \"road\"\n",
        "})\n",
        "\n",
        "risk_nodes = pd.DataFrame({\n",
        "    \"name\": edges[\"target\"].unique(),\n",
        "    \"type\": \"risk\"\n",
        "})\n",
        "\n",
        "nodes = pd.concat([road_nodes, risk_nodes], ignore_index=True)\n",
        "\n",
        "#export tp use in Cytoscape\n",
        "edges.to_csv(\"road_risk_edges.csv\", index=False)\n",
        "nodes.to_csv(\"nodes.csv\", index=False)\n",
        "\n"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "SvWesoIPOtYK",
        "outputId": "b1a44734-6a1d-4523-9614-64aa78e7da7f"
