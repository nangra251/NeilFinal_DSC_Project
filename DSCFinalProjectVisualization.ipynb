    },
    {
      "cell_type": "code",
      "source": [
        "##Creating Severity Column for Lin_Reg Line Analysis\n",
        "dfx = combined_df.copy()\n",
        "#Weight on Each Type of Severity\n",
        "dfx[\"severity\"] = (\n",
        "    dfx[\"Fatal Injuries\"] * 4 +\n",
        "    dfx[\"Suspected Serious Injuries\"] * 3 +\n",
        "    dfx[\"Suspected Minor Injuries\"] * 2 +\n",
        "    dfx[\"Possible Injuries\"] * 1\n",
        ")\n",
        "#dfx.to_csv(\"detroitcrash.csv\", index=False)"
      ],
      "metadata": {
        "id": "Nufp_wkRsJwk"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "import seaborn as sns\n",
        "import matplotlib.pyplot as plt\n",
        "heatmap_data = (\n",
        "    dfx.groupby([\"Weekday\", \"Hour\"])[\"severity\"]\n",
        "      .mean()\n",
        "      .reset_index()\n",
        ")\n",
        "\n",
        "\n",
        "heatmap_pivot = heatmap_data.pivot(\n",
        "    index=\"Weekday\",\n",
        "    columns=\"Hour\",\n",
        "    values=\"severity\"\n",
        ")\n",
        "\n",
        "heatmap_pivot.index = heatmap_pivot.index.map({\n",
        "    1: \"Monday\", 2: \"Tuesday\", 3: \"Wednesday\",\n",
        "    4: \"Thursday\", 5: \"Friday\", 6: \"Saturday\", 7: \"Sunday\"\n",
        "})\n",
        "heatmap_pivot.columns = heatmap_pivot.columns.map(\n",
        "    lambda x: f\"{(int(x) % 12) or 12}{'AM' if x < 12 else 'PM'}\"\n",
        ")\n",
        "\n",
        "sns.heatmap(\n",
        "    heatmap_pivot,\n",
        "    cmap=\"viridis\",\n",
        "    linewidths=0.3,\n",
        "    linecolor=\"white\",\n",
        "    cbar_kws={\"label\": \"Severity of Crashes\"}\n",
        ")\n",
        "\n",
        "plt.title(\"Severity in Crash Patterns by Time of Day and Week\", fontsize=14, weight=\"bold\")\n",
        "plt.xlabel(\"Hour (0–23)\")\n",
        "plt.ylabel(\"Day of Week\")\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
